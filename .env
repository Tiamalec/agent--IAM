# 飞书核心配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
FEISHU_SKILLS_ENABLED=true  # 启用真实API

# 事件订阅配置（如果启用）
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxx

# Webhook配置
FEISHU_WEBHOOK_URL=https://your-domain.com/feishu/webhook

# 生产环境配置
PRODUCTION_MODE=true
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secure_production_secret_key