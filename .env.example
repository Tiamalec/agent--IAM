# ================================================
# AI Agent IAM 系统 - 环境变量配置示例
# ================================================

# ============ 基本配置 ============
# IAM系统密钥（生产环境必须修改）
IAM_SECRET_KEY=your_super_secret_key_change_in_production

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============ 飞书集成配置 ============
# 飞书应用凭证（从飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth2.0回调地址（必须与飞书应用配置一致）
FEISHU_REDIRECT_URI=https://your-domain.com/api/feishu/callback

# Webhook配置（可选，用于实时同步用户/部门变更）
FEISHU_WEBHOOK_VERIFICATION_TOKEN=your_webhook_verification_token
FEISHU_WEBHOOK_ENCRYPT_KEY=your_webhook_encrypt_key

# ============ 数据库配置 ============
# 数据库类型：sqlite, postgresql, mysql
DATABASE_TYPE=sqlite

# SQLite配置（开发环境）
DATABASE_URL=sqlite:///iam_database.db

# PostgreSQL配置示例（生产环境）
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://username:password@localhost:5432/iam_database

# MySQL配置示例
# DATABASE_TYPE=mysql
# DATABASE_URL=mysql://username:password@localhost:3306/iam_database

# ============ 缓存配置 ============
# Redis缓存（可选，生产环境推荐）
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_ENABLED=false

# ============ 监控和告警配置 ============
# 监控端点启用
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true

# 告警Webhook（可选）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=XXXX

# ============ API服务器配置 ============
# 服务器绑定地址和端口
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "https://your-frontend.com"]

# ============ 安全配置 ============
# API速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒

# JWT令牌配置
TOKEN_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ============ 审计日志配置 ============
# 审计日志存储
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=audit_logs.jsonl
AUDIT_LOG_MAX_SIZE_MB=100
AUDIT_LOG_BACKUP_COUNT=10

# ============ 飞书集成高级配置 ============
# 组织架构同步频率（分钟）
FEISHU_ORG_SYNC_INTERVAL=60

# 自动同步用户变更
FEISHU_AUTO_SYNC_USER_CHANGES=true

# 权限映射配置文件路径
FEISHU_PERMISSION_MAPPINGS=feishu_permission_mappings.json

# ============ 开发模式配置 ============
# 开发模式（启用调试功能）
DEBUG=false

# 模拟飞书API（开发测试用）
FEISHU_MOCK_API=false

# ================================================
# 部署说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置
# 3. 生产环境务必修改所有敏感信息
# ================================================